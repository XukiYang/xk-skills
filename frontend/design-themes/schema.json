{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Design Specification",
  "description": "Core design spec — compiler derives all CSS variables from these fields.",
  "type": "object",
  "required": ["name", "labels", "backgrounds", "radius", "shadows", "typography", "spatialMetaphor"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Skill identifier, kebab-case (e.g. 'sunset-warm')"
    },
    "description": {
      "type": "string",
      "description": "One-line description of the design language"
    },
    "mode": {
      "type": "string",
      "enum": ["light", "dark"],
      "default": "light",
      "description": "Primary mode. 'dark' means the base tokens are dark-themed."
    },
    "colors": {
      "type": "object",
      "description": "Semantic color palette (6-12 colors). Keys map to --color-* variables.",
      "properties": {
        "blue": { "type": "string" },
        "red": { "type": "string" },
        "green": { "type": "string" },
        "purple": { "type": "string" },
        "orange": { "type": "string" },
        "cyan": { "type": "string" },
        "yellow": { "type": "string" },
        "pink": { "type": "string" },
        "indigo": { "type": "string" },
        "teal": { "type": "string" },
        "mint": { "type": "string" },
        "brown": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "labels": {
      "type": "object",
      "description": "Text label opacity hierarchy.",
      "properties": {
        "primary": { "type": "string", "description": "Main text color" },
        "secondary": { "type": "string", "description": "Supporting text" },
        "tertiary": { "type": "string", "description": "Placeholder / hints" },
        "quaternary": { "type": "string", "description": "Disabled / faintest" }
      },
      "required": ["primary", "secondary", "tertiary", "quaternary"]
    },
    "backgrounds": {
      "type": "object",
      "description": "Surface background hierarchy.",
      "properties": {
        "primary": { "type": "string", "description": "Page-level background" },
        "secondary": { "type": "string", "description": "Card / elevated surface" },
        "tertiary": { "type": "string", "description": "Grouped content background" }
      },
      "required": ["primary", "secondary", "tertiary"]
    },
    "fills": {
      "type": "object",
      "description": "Fill overlays for interactive elements. Compiler derives from labels if omitted.",
      "properties": {
        "primary": { "type": "string" },
        "secondary": { "type": "string" },
        "tertiary": { "type": "string" },
        "quaternary": { "type": "string" }
      }
    },
    "grays": {
      "type": "object",
      "description": "Neutral gray scale. Keys map to --* variables (black, gray, gray-2..6, white).",
      "properties": {
        "black": { "type": "string" },
        "gray": { "type": "string" },
        "gray-2": { "type": "string" },
        "gray-3": { "type": "string" },
        "gray-4": { "type": "string" },
        "gray-5": { "type": "string" },
        "gray-6": { "type": "string" },
        "white": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "radius": {
      "type": "object",
      "description": "Border radius scale. Compiler derives intermediates from xs/lg.",
      "properties": {
        "xs": { "type": "string", "description": "Smallest radius (4-6px typical)" },
        "sm": { "type": "string", "description": "Small radius" },
        "md": { "type": "string", "description": "Medium radius" },
        "lg": { "type": "string", "description": "Large radius" },
        "xl": { "type": "string", "description": "Extra large radius" }
      },
      "required": ["xs", "lg"]
    },
    "shadows": {
      "type": "object",
      "description": "Shadow scale. Compiler generates md/lg from sm if omitted.",
      "properties": {
        "sm": { "type": "string", "description": "Subtle lift" },
        "md": { "type": "string", "description": "Card elevation" },
        "lg": { "type": "string", "description": "Modal / floating" },
        "thumb": { "type": "string", "description": "Slider/thumb shadow. Defaults to sm." }
      },
      "required": ["sm"]
    },
    "typography": {
      "type": "object",
      "description": "Font stacks. Heading defaults to body if omitted.",
      "properties": {
        "body": { "type": "string", "description": "Body font stack (e.g. 'Inter, system-ui, sans-serif')" },
        "heading": { "type": "string", "description": "Heading font stack. Falls back to body." }
      },
      "required": ["body"]
    },
    "typographyScale": {
      "type": "object",
      "description": "Optional type scale overrides (sizes, line-heights, letter-spacing, weights).",
      "properties": {
        "sizes": {
          "type": "object",
          "description": "Font sizes, keys map to --text-* (e.g. 'body': '16px', 'headline': '16px')",
          "additionalProperties": { "type": "string" }
        },
        "lineHeights": {
          "type": "object",
          "description": "Line heights, keys map to --lh-*",
          "additionalProperties": { "type": "string" }
        },
        "letterSpacing": {
          "type": "object",
          "description": "Letter spacing, keys map to --ls-*",
          "additionalProperties": { "type": "string" }
        },
        "weights": {
          "type": "object",
          "description": "Font weights, keys map to --weight-* (e.g. 'regular': '400', 'bold': '700')",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "spacing": {
      "type": "object",
      "description": "Spacing scale. Keys map to --space-* (e.g. '0': '0px', '1': '4px', '2': '8px').",
      "additionalProperties": { "type": "string" }
    },
    "motion": {
      "type": "object",
      "description": "Motion tokens: durations and easing curves.",
      "properties": {
        "durations": {
          "type": "object",
          "description": "Duration values, keys map to --duration-* (e.g. 'fast': '0.15s', 'normal': '0.3s')",
          "additionalProperties": { "type": "string" }
        },
        "easings": {
          "type": "object",
          "description": "Easing curves, keys map to --ease-* (e.g. 'default': 'cubic-bezier(...)')",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "opacity": {
      "type": "object",
      "description": "Opacity tokens. Keys map to --opacity-* (e.g. 'disabled': '0.35', 'muted': '0.5').",
      "properties": {
        "disabled": { "type": "string" },
        "muted": { "type": "string" },
        "subtle": { "type": "string" },
        "hover": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "spatialMetaphor": {
      "type": "string",
      "enum": ["flat", "card-elevation", "frosted-glass", "ambient-glow", "custom"],
      "description": "Determines style.css template: flat=no extras, card-elevation=card utilities, frosted-glass=glass surfaces, ambient-glow=blobs + glass, custom=escape hatch"
    },
    "focusRing": {
      "type": "string",
      "description": "Focus ring color. Defaults to colors.blue."
    },
    "componentSizes": {
      "type": "object",
      "description": "Optional component dimension overrides.",
      "properties": {
        "btnHeightSm": { "type": "string" },
        "btnHeightMd": { "type": "string" },
        "btnHeightLg": { "type": "string" },
        "toggleWidth": { "type": "string" },
        "toggleHeight": { "type": "string" },
        "toggleThumb": { "type": "string" }
      }
    },
    "darkOverrides": {
      "type": "object",
      "description": "Override specific tokens in dark mode. Compiler auto-derives if omitted.",
      "properties": {
        "colors": { "type": "object", "additionalProperties": { "type": "string" } },
        "labels": { "type": "object" },
        "backgrounds": { "type": "object" },
        "fills": { "type": "object" },
        "shadows": { "type": "object" }
      }
    },
    "customStyleCSS": {
      "type": "string",
      "description": "Escape hatch: raw CSS appended to style.css when spatialMetaphor='custom'."
    }
  }
}
